{
  "expo": {
    "name": "Malcci 💕",
    "slug": "malcci",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "malcci",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/icon.png",
      "supportsTablet": true,
      "bundleIdentifier": "com.leonardo.malcci"
    },
    "android": {
      "package": "com.leonardo.malcci",
      "adaptiveIcon": {
        "backgroundColor": "#C85A7C",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 150,
          "resizeMode": "contain",
          "backgroundColor": "#FAE7EF"
        }
      ],
      "expo-audio",
      [
        "expo-image-picker",
        {
          "photosPermission": "O app acessa suas fotos para você adicionar imagens às memórias do casal."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#C85A7C"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
